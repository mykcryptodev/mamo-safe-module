BASE_RPC_URL=
ETHERSCAN_API_KEY=

# Deploy script inputs (Pawthereum-specific)
SAFE=
MAMO_STRATEGY=
# Comma-separated parallel lists. Same length on both. Sum of bps must be <= 10000;
# whatever doesn't sum to 10000 auto-compounds into protectedPrincipal each cycle.
# Leave both empty to deploy with no recipients (100% compound from day one).
RECIPIENT_ADDRESSES=
RECIPIENT_BPS=
PROTECTED_PRINCIPAL=
EXECUTION_INTERVAL=604800
MIN_CLAIM_AMOUNT=1000000
